{
  "scripts": {
    "compile-computer": "cargo build --target=wasm32-unknown-unknown --release",
    "optimise-and-copy-computer": "wasm-opt -O3 --enable-bulk-memory-opt -o src/computer.wasm computer/target/wasm32-unknown-unknown/release/computer.wasm",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "cd esbuild; go run . serve",
    "typecheck": "tsc --noEmit",
    "format:superhtml": "superhtml fmt *.html",
    "format:prettier": "prettier --write --prose-wrap=always './**/*.{mjs,ts,md,json,js,yml,yaml,css}'",
    "format:clang": "clang-format -i src/{vert,frag}.glsl",
    "format:rust": "(cd computer; cargo fmt)"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.68",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  },
  "packageManager": "pnpm@10.31.0+sha512.e3927388bfaa8078ceb79b748ffc1e8274e84d75163e67bc22e06c0d3aed43dd153151cbf11d7f8301ff4acb98c68bdc5cadf6989532801ffafe3b3e4a63c268"
}
