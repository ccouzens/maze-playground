{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "compile-computer": {
      "inputs": [
        "computer/Cargo.lock",
        "computer/Cargo.toml",
        "computer/src/**/*.rs"
      ],
      "outputs": [
        "computer/target/wasm32-unknown-unknown/release/computer.wasm"
      ]
    },
    "optimise-and-copy-computer": {
      "dependsOn": ["compile-computer"],
      "inputs": [
        "computer/target/wasm32-unknown-unknown/release/computer.wasm"
      ],
      "outputs": ["src/computer.wasm"]
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["optimise-and-copy-computer"]
    },
    "build": {
      "dependsOn": ["optimise-and-copy-computer"]
    },
    "preview": {
      "dependsOn": ["build"],
      "persistent": true,
      "cache": false
    },
    "format": {
      "dependsOn": [
        "format:superhtml",
        "format:prettier",
        "format:clang",
        "format:rust"
      ]
    }
  }
}
